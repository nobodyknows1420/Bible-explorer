export default function BibleExplorer() {
  const [search, setSearch] = useState("");
  const [results, setResults] = useState([]);
  const [selected, setSelected] = useState(null);
  const [aiAnswer, setAiAnswer] = useState("");
  const [loading, setLoading] = useState(false);

  // SMART SEARCH
  const handleSearch = () => {
    const filtered = Object.keys(bibleData).filter((key) => {
      const item = bibleData[key];
      return (
        key.toLowerCase().includes(search.toLowerCase()) ||
        item.title.toLowerCase().includes(search.toLowerCase()) ||
        item.description.toLowerCase().includes(search.toLowerCase())
      );
    });

    setResults(filtered);
    setSelected(null);
    setAiAnswer("");
  };

  // 🤖 REAL AI SEARCH
  const handleAISearch = async () => {
    setLoading(true);
    setAiAnswer("");

    try {
      const res = await fetch("/api/ai", {
        method: "POST",
        body: JSON.stringify({ query: search }),
      });

      const data = await res.json();
      setAiAnswer(data.answer);
    } catch (err) {
      setAiAnswer("Error getting AI response");
    }

    setLoading(false);
  };

  return (
    <div
      className="min-h-screen p-4"
      style={{
        background: "linear-gradient(to bottom right, #1e3a8a, #3b82f6)",
        fontFamily: "Comfortaa, sans-serif",
      }}
    >
      <div className="max-w-3xl mx-auto">
        <h1 className="text-3xl md:text-4xl font-bold text-white mb-4 text-center">
          Bible Explorer
        </h1>

        <div className="flex flex-col sm:flex-row gap-2">
          <input
            className="p-3 rounded w-full"
            placeholder="Search anything (e.g. Jesus, faith, sin...)"
            value={search}
            onChange={(e) => setSearch(e.target.value)}
          />
          <button
            onClick={handleSearch}
            className="bg-white text-blue-700 px-4 py-2 rounded font-semibold"
          >
            Search
          </button>
          <button
            onClick={handleAISearch}
            className="bg-yellow-300 text-black px-4 py-2 rounded font-semibold"
          >
            AI Search
          </button>
        </div>

        {/* Results */}
        <div className="mt-4 grid gap-2">
          {results.map((key) => (
            <button
              key={key}
              onClick={() => setSelected(bibleData[key])}
              className="bg-white/90 p-3 rounded text-left"
            >
              {bibleData[key].title}
            </button>
          ))}
        </div>

        {/* Selected */}
        {selected && (
          <div className="mt-6 bg-white p-4 rounded shadow">
            <h2 className="text-2xl font-bold">{selected.title}</h2>
            <p className="text-sm text-gray-500 mb-2">
              {selected.testament}
            </p>
            <img
              src={selected.image}
              alt={selected.title}
              className="w-full h-auto my-3 rounded"
            />
            <p>{selected.description}</p>
          </div>
        )}

        {/* AI Answer */}
        {(aiAnswer || loading) && (
          <div className="mt-6 bg-yellow-100 p-4 rounded">
            <h3 className="font-bold mb-2">AI Explanation</h3>
            {loading ? <p>Thinking...</p> : <p>{aiAnswer}</p>}
          </div>
        )}
      </div>
    </div>
  );
}
